# ==========================================================================
# Backend environment — copy this file to  backend/.env  and fill the values.
# Get them from: Supabase Dashboard -> Project Settings -> API
# ==========================================================================

# Project URL (same one you put in frontend/js/config.js)
SUPABASE_URL=https://YOUR-NEW-PROJECT-REF.supabase.co

# service_role key — SECRET. Bypasses RLS. NEVER put this in frontend code,
# never commit it. Backend only.
SUPABASE_SERVICE_KEY=PASTE-YOUR-SERVICE-ROLE-KEY-HERE

# NOTE: there is no ADMIN_TOKEN. Admin access is gated by Supabase Auth (JWT) +
# membership in the server-only public.admins table (see admin_setup.sql).
# These two variables above are the only ones the backend reads.
